		{
			"name": "Quiz Simulator Tests",
			"description": "Folder khusus untuk simulasi pengetesan alur kuis sesuai spesifikasi sistem simulator",
			"item": [
				{
					"name": "Step 1 - Request Quiz (Start)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"pm.test(\"State is DECISION_REQUIRED\", function () {",
									"    pm.expect(response.state).to.equal(\"DECISION_REQUIRED\");",
									"    pm.expect(response.message).to.equal(\"Kamu mau test terkait topik ini untuk mendapatkan score?\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"topic\": \"javascript array\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/quizzes/start",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"quizzes",
								"start"
							]
						}
					},
					"response": []
				},
				{
					"name": "Step 2 - Decision YES",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"pm.test(\"State is QUIZ_STARTED\", function () {",
									"    pm.expect(response.state).to.equal(\"QUIZ_STARTED\");",
									"});",
									"if (response.data && response.data.attemptId) {",
									"    pm.environment.set(\"currentAttemptId\", response.data.attemptId);",
									"}",
									"if (response.data && response.data.quiz && response.data.quiz.questions.length > 0) {",
									"    pm.environment.set(\"currentQuestionId\", response.data.quiz.questions[0].id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"topic\": \"javascript array\",\n  \"decision\": \"YES\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/quizzes/decision",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"quizzes",
								"decision"
							]
						}
					},
					"response": []
				},
				{
					"name": "Step 2 - Decision NO (Graceful Exit)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"pm.test(\"State is EXIT\", function () {",
									"    pm.expect(response.state).to.equal(\"EXIT\");",
									"    pm.expect(response.message).to.equal(\"Oke semangat belajar ya\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"topic\": \"javascript array\",\n  \"decision\": \"NO\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/quizzes/decision",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"quizzes",
								"decision"
							]
						}
					},
					"response": []
				},
				{
					"name": "Step 3 - Submit Answer",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"pm.test(\"State is ANSWER_SUBMITTED\", function () {",
									"    pm.expect(response.state).to.equal(\"ANSWER_SUBMITTED\");",
									"    pm.expect(response.data).to.have.property(\"correct\");",
									"    pm.expect(response.data).to.have.property(\"score\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"attemptId\": \"{{currentAttemptId}}\",\n  \"questionId\": \"{{currentQuestionId}}\",\n  \"answerText\": \"A\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/quizzes/answer",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"quizzes",
								"answer"
							]
						}
					},
					"response": []
				},
				{
					"name": "Step 4 - Finish Quiz",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"pm.test(\"State is QUIZ_FINISHED\", function () {",
									"    pm.expect(response.state).to.equal(\"QUIZ_FINISHED\");",
									"    pm.expect(response.data).to.have.property(\"totalScore\");",
									"    pm.expect(response.data).to.have.property(\"maxScore\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/quizzes/finish/{{currentAttemptId}}",
							"host": [
