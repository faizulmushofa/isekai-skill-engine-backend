# ==========================================
# AETHER SYSTEM BACKEND ENVIRONMENT SETTINGS
# ==========================================

# 1. DATABASE (Supabase PostgreSQL)
# Ambil dari dashboard Supabase: Project Settings -> Database -> Connection string (URI)
# Ingat: ganti [YOUR-PASSWORD] dengan password asli database kamu.
# Jika pakai Prisma dengan Supabase, disarankan pakai port 6543 dan ?pgbouncer=true
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Karena Prisma butuh koneksi langsung untuk migrasi (tanpa pgbouncer), biasanya kita butuh DIRECT_URL
# Supabase menyediakan Session mode di port 5432 untuk DIRECT_URL:
# DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# 2. JWT (JSON Web Token)
JWT_ACCESS_SECRET="super_secret_jwt_key_please_change_this"
JWT_REFRESH_SECRET="super_secret_refresh_key_please_change_this"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# 3. SMTP (Untuk Pengiriman OTP / Email)
# Contoh menggunakan Brevo / Sendgrid
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USER="your_email@example.com"
SMTP_PASS="your_smtp_password"
SMTP_FROM_EMAIL="noreply@aethersystem.com"
SMTP_FROM_NAME="Aether Gateway"

# 4. SERVER CONFIG
PORT=3090
FRONTEND_URL="http://localhost:3000"

ADMIN_FRONTEND_URL=http://localhost:3001
